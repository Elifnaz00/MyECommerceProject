@model ShoppingCartViewModel

@{
    ViewData["Title"] = "Sepet";
    Layout = "~/Views/Shared/Layout.cshtml";
    var token = Context.Request.Cookies["ApiAccessToken"];
}

<div class="container mt-5 mb-5">

    <h2 class="mb-4">Alışveriş Sepeti</h2>

    @if (Model == null || !Model.BasketItems.Any())
    {
        <div class="alert alert-info">
            Sepetinizde ürün bulunmamaktadır.
        </div>
    }
    else
    {
        <table class="table table-bordered text-center align-middle">
            <thead class="table-light">
                <tr>
                    <th>Ürün</th>
                    <th>Fiyat</th>
                    <th>Miktar</th>
                    <th>Toplam</th>
                    <th>Sil</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.BasketItems)
                {
                    <tr>
                        <td class="d-flex align-items-center">
                            <img src="@item.Product.ImageUrl"
                                 style="width:80px;height:80px;object-fit:cover;margin-right:15px;" />

                            <div>
                                <strong>@item.Product.Title</strong>
                                <br />
                                <small>@item.Product.Description</small>
                            </div>
                        </td>

                        <td>@($"{item.Product.Price:N2} TL")</td>

                        <td>
                            <div class="d-flex justify-content-center align-items-center" style="gap:5px;">

                                <button class="btn btn-outline-secondary minus-btn" data-id="@item.Id">-</button>

                                <input type="number"
                                       value="@item.Quantity"
                                       class="form-control text-center quantity-input"
                                       data-id="@item.Id"
                                       min="1"
                                       max="100"
                                       style="width:50px;">

                                <button class="btn btn-outline-secondary plus-btn" data-id="@item.Id">+</button>

                            </div> 
                        </td>

                        <td class="item-total">
                            @($"{(item.Product.Price * item.Quantity):N2} TL")
                        </td>

                        <td>
                            <button class="btn btn-danger btn-sm remove-item" data-id="@item.Id">Sil</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="text-end mt-4">
            <h4>
                Toplam : <span id="cart-total">@($"{Model.TotalPrice:N2} TL")</span>
            </h4>

            <a href="/Order/Index" class="btn btn-primary mt-3">Sepeti Onayla</a>
        </div>
    }
</div>

@section scripts {
    <script>

        const token = "@(token ?? "")";

        $(document).ready(function(){   

            function updateQuantity(id, qty){
                $.ajax({
                    url: "https://localhost:7177/api/v1/BasketItem/UpdateBasketItem/"+id,
                    type: "PUT",
                    contentType: "application/json",
                    data: JSON.stringify({ quantity: qty }),
                    beforeSend: function(xhr){
                        if(token){
                            xhr.setRequestHeader("Authorization","Bearer "+token);
                        }
                    },
                    success: function(res){
                        if(res.isSuccess){
                            loadCartCount(); 
                            refreshPage();
                        } else {
                            alert(res.message || "Sepet güncellenemedi.");
                        }
                    },
                    error: function(){
                        alert("Sepet güncellenirken hata oluştu.");
                    }
                });
            }

            $(".plus-btn").click(function(){
                var id = $(this).data("id");
                var input = $(".quantity-input[data-id='"+id+"']");
                var qty = parseInt(input.val()) + 1;
                updateQuantity(id, qty);
            });

            $(".minus-btn").click(function(){
                var id = $(this).data("id");
                var input = $(".quantity-input[data-id='"+id+"']");
                var qty = parseInt(input.val()) - 1;
                if(qty < 1) qty = 1;
                updateQuantity(id, qty);
            });

            $(".quantity-input").change(function(){
                var id = $(this).data("id");
                var qty = parseInt($(this).val());
                if(qty < 1) qty = 1;
                updateQuantity(id, qty);
            });

            $(".remove-item").click(function(){
                if(!confirm("Ürünü silmek istiyor musunuz?")) return;

                var id = $(this).data("id");

                $.ajax({
                    url: "https://localhost:7177/api/v1/BasketItem/DeleteBasketItems/"+id,
                    type: "DELETE",
                    beforeSend: function(xhr){
                        if(token){
                            xhr.setRequestHeader("Authorization","Bearer "+token);
                        }
                    },
                    success: function(res){
                        if(res.isSuccess){
                            loadCartCount(); 
                            refreshPage();
                            refreshPage();
                        } else {
                            alert(res.message || "Ürün silinemedi.");
                        }
                    },
                    error: function(){
                        alert("Ürün silinirken hata oluştu.");
                    }
                });
            });

        });
    </script>
}
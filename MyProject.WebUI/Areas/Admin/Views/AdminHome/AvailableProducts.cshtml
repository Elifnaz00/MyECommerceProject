@using MyProject.WebUI.Models.AdminModel.ProductModel
@model IEnumerable<ProductListViewModel>
@{
    ViewData["Title"] = "AvailableProducts";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="row">
    <div class="col-lg-12 col-md-12 col-12 col-sm-12">
        <div class="card">
            <div class="card-header">
                <h4>Mevcut Ürünler</h4>
            </div>
            <a asp-area="Admin" asp-controller="Product" asp-action="Create"
               class="btn btn-primary btn-sm">Ürün Ekle</a>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <tr>
                            <th>Ürün İd</th>
                            <th>Ürün Adı</th>
                            <th>Ürün Açıklaması</th>
                            <th>Fiyat</th>
                            <th>Beden</th>
                            <th>Renk</th>
                            <th>Kategori</th>
                            <th>Oluşturulma Tarihi</th>
                            <th>Stock</th>
                            <th>Düzenle</th>
                            <th>Detay</th>
                        </tr>

                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="product-id">@item.Id</td>
                                <td>@item.Title</td>
                                <td>@item.Description</td>
                                <td>@item.Price</td>
                                <td>@item.Size</td>
                                <td>@item.Color</td>
                                <td>@item.CategoryCategoryName</td>
                                <td>@item.CreateDate</td>
                                <td>@item.Stock</td>

                                <td>
                                    <a asp-area="Admin" asp-controller="Product" asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-primary btn-sm">Düzenle</a>

                                    <button class="btn btn-delete-product btn-danger">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </td>

                                <td>
                                    <button class="btn btn-info btn-sm btn-product-detail"
                                            data-id="@item.Id">
                                        Ürün Detay
                                    </button>
                                </td>
                            </tr>
                        }
                    </table>
                </div>

            
            </div>
        </div>
    </div>
</div>

